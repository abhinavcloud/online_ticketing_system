        <mxCell id="AtqJ98JdHEPPUzc0A_OA-63" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="countActiveUsers" vertex="1">
