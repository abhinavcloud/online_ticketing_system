        <mxCell id="AtqJ98JdHEPPUzc0A_OA-64" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;labelBorderColor=none;" value="availbleUsers = maxUser-activeUserCount&lt;br&gt;releasableUsers = min (avaiableUserCount, availableSeatCount*2)" vertex="1">
          <mxGeometry height="62" width="145" x="570" y="97" as="geometry" />
        </mxCell>
        <mxCell id="AtqJ98JdHEPPUzc0A_OA-67" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;labelBorderColor=none;" value="userId&lt;br&gt;eventId&lt;br&gt;queuePosition&lt;br&gt;status {waiting, allowed)&lt;br&gt;countActiveUsers{status.waiting}&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
