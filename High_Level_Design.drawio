        </mxCell>
        <mxCell id="AtqJ98JdHEPPUzc0A_OA-72" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Redis" vertex="1">
          <mxGeometry height="30" width="60" x="843" y="28" as="geometry" />
        </mxCell>
        <mxCell id="AtqJ98JdHEPPUzc0A_OA-73" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="websocket: return when userid status = Allowed" vertex="1">
          <mxGeometry height="30" width="126" x="399" y="138" as="geometry" />
        </mxCell>
        <mxCell id="AtqJ98JdHEPPUzc0A_OA-74" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="if userid status= Allowed" vertex="1">
          <mxGeometry height="30" width="162" x="376" y="247.5" as="geometry" />
        </mxCell>
        <mxCell id="AtqJ98JdHEPPUzc0A_OA-77" edge="1" parent="1" source="dMjLUbfOzXkTQUA531XS-28" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.637;entryDx=0;entryDy=0;entryPerimeter=0;" target="8WxnnMFKF0vpLti6PXvg-43">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1077" y="337" />
              <mxPoint x="1077" y="380" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="AtqJ98JdHEPPUzc0A_OA-78" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="lockCount:{seatId}, &lt;br&gt;count(Seat.seatStatus == AVAILABLE}" vertex="1">
          <mxGeometry height="30" width="246" x="820" y="134" as="geometry" />
        </mxCell>
        <mxCell id="AtqJ98JdHEPPUzc0A_OA-79" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;&quot;&gt;avaiableSeatCount = lockCount:{seatId}- count(Seat.seatStatus == AVAILABLE)&amp;nbsp;&lt;/span&gt;" vertex="1">
          <mxGeometry height="30" width="242" x="568" y="168" as="geometry" />
        </mxCell>
        <mxCell id="AtqJ98JdHEPPUzc0A_OA-80" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;text-align: start; font-family: &amp;quot;Segoe UI&amp;quot;; font-size: 14px; line-height: 20px;&quot;&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Per-event waiting room:&lt;/strong&gt; Queue is scoped to &lt;strong&gt;EventId&lt;/strong&gt; to isolate viral events and avoid cross-event contention.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Admission control (not correctness):&lt;/strong&gt; Queue releases users based on &lt;strong&gt;approx capacity&lt;/strong&gt;, not strong consistency.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Capacity formula:&lt;/strong&gt; &lt;code&gt;availableSeatCount ≈ dbAvailableCount(RDS AVAILABLE) − lockedCount(Redis holds)&lt;/code&gt; (bounded at 0).&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Concurrency cap:&lt;/strong&gt; &lt;code&gt;availableUsers = maxUser − activeUserCount&lt;/code&gt; to hard-limit active seat-map/booking traffic.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Release formula:&lt;/strong&gt; &lt;code&gt;releasableUsers = min(availableUsers, availableSeatCount * oversubscriptionFactor)&lt;/code&gt; (factor starts at &lt;strong&gt;2&lt;/strong&gt;).&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Oversubscription is tunable:&lt;/strong&gt; Reduce/raise &lt;strong&gt;oversubscriptionFactor&lt;/strong&gt; based on observed reserve-fail rate vs seat idle time.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;WebSocket push:&lt;/strong&gt; Queue notifies clients via &lt;strong&gt;WebSocket&lt;/strong&gt; when released to avoid polling storms.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Leased admission:&lt;/strong&gt; Released users get a short &lt;strong&gt;lease/TTL&lt;/strong&gt;; expiry reclaims slots and decrements activeUserCount.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Seat map is informational:&lt;/strong&gt; Seat map may be stale; it’s validated again when user is released.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Correctness at reservation:&lt;/strong&gt; &lt;strong&gt;ReserveTicket&lt;/strong&gt; re-checks &lt;strong&gt;RDS + Redis&lt;/strong&gt; for selected seatIds before locking.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Atomic multi-seat lock:&lt;/strong&gt; Reserve either locks &lt;strong&gt;all seats atomically&lt;/strong&gt; or fails (enforces &lt;strong&gt;no partial booking&lt;/strong&gt;).&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Fast fail UX:&lt;/strong&gt; If any selected seat is unavailable/locked, reservation fails and user can re-enter queue.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Lock semantics:&lt;/strong&gt; Redis holds are &lt;strong&gt;per-seat locks with TTL&lt;/strong&gt;; release happens on cancel/failure or TTL expiry.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Confirm writes truth:&lt;/strong&gt; Confirmation updates &lt;strong&gt;RDS seats → BOOKED&lt;/strong&gt; transactionally for all selected seats.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Idempotent booking:&lt;/strong&gt; Reserve/Confirm are &lt;strong&gt;idempotent&lt;/strong&gt; via reservationId/idempotency key to handle retries/double submits.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Notifications:&lt;/strong&gt; Send Email/SMS on booking &lt;strong&gt;success/failure&lt;/strong&gt; via Notification Service.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Read-heavy optimization:&lt;/strong&gt; Browse traffic served via &lt;strong&gt;Redis cache&lt;/strong&gt; for events/venues/performers/locations.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Read/write separation:&lt;/strong&gt; Browse remains highly available even during booking spikes; booking path stays consistent via locks.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="1293" x="788" y="872" as="geometry" />
        </mxCell>
